# ─────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in your values
# NEVER commit .env to Git
#
#   cp .env.example .env
#   # then edit .env with your real API key
# ─────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────
# Which provider to use: nebius | openai | anthropic
LLM_PROVIDER=nebius

# Your API key for the chosen provider
LLM_API_KEY=your-api-key-here

# (Optional) Override the default model for your provider
# Nebius default  : meta-llama/Meta-Llama-3.1-70B-Instruct
# OpenAI default  : gpt-4o-mini
# Anthropic default: claude-3-haiku-20240307
# LLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
