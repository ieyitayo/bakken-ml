# ─────────────────────────────────────────────────────────────
# .gitignore — Bakken Basin ML Project
# ─────────────────────────────────────────────────────────────

# ── Secrets — NEVER commit these ─────────────────────────────
.env
*.key
*.pem

# ── Data files — tracked with DVC, not Git ───────────────────
data/raw/
data/processed/
!data/.gitkeep

# ── Model artifacts ───────────────────────────────────────────
mlruns/
mlartifacts/
models/
*.pkl
*.joblib
*.model
*.pt
*.h5

# ── Python cache ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.eggs/

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── OS / editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Virtual environments ──────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Temp / logs ───────────────────────────────────────────────
*.log
/tmp/
